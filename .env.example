# Core mode
ASSISTANT_MODE=local
REMOTE_ASSISTANT_URL=http://192.168.1.42:8080

# Identity
ASSISTANT_USER_NAME=Ben
TIMEZONE=America/New_York

# Camera
CAMERA_INDEX=0
FRAME_WIDTH=640
FRAME_HEIGHT=480
FACE_STABLE_FRAMES=5
FACE_MATCH_TOLERANCE=0.5

# Morning trigger
MORNING_START=05:00
MORNING_END=11:30
GREETING_COOLDOWN_MINUTES=120
TRIGGER_STATE_FILE=data/trigger_state.json

# Enrollment and recognition store
ENROLLMENTS_FILE=data/enrollments.json

# Weather (OpenWeatherMap)
WEATHER_PROVIDER=openweathermap
WEATHER_API_KEY=
WEATHER_LAT=40.7128
WEATHER_LON=-74.0060
WEATHER_UNITS=imperial

# Calendar (Google)
CALENDAR_PROVIDER=google
GOOGLE_CLIENT_SECRET_FILE=data/google_client_secret.json
GOOGLE_TOKEN_FILE=data/google_token.json
GOOGLE_CALENDAR_IDS=primary

# Speech (Piper)
PIPER_BIN=/usr/local/bin/piper
PIPER_MODEL=/opt/piper/en_US-lessac-medium.onnx
PIPER_CONFIG=/opt/piper/en_US-lessac-medium.onnx.json
AUDIO_PLAYER_BIN=aplay
AUDIO_DEVICE=default

# UI
UI_HOST=0.0.0.0
UI_PORT=8080
UI_POLL_MS=250

# Optional logging level
LOG_LEVEL=INFO
