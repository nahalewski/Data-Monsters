{
  "metadata": {
    "blueprint_version": 1,
    "name": "03 - Claim Handler",
    "description": "Template blueprint generated from shared Lead Management System plan.",
    "scenario": {
      "sequential": true,
      "auto_commit": true,
      "max_errors": 3,
      "schedule": {
        "type": "immediately"
      }
    }
  },
  "subflows": [
    {
      "name": "Main flow",
      "flow": [
        {
          "id": 1,
          "module": "webhooks:customWebhook",
          "version": 1,
          "note": "Trigger: sms_inbound webhook",
          "parameters": {
            "webhook_name": "sms_inbound"
          },
          "mapper": {}
        },
        {
          "id": 2,
          "module": "tools:textParser",
          "version": 1,
          "note": "Parse CLAIM command and tokens",
          "parameters": {},
          "mapper": {
            "command": "{{upper(trim(1.body))}}"
          }
        },
        {
          "id": 3,
          "module": "google-sheets:searchRows",
          "version": 1,
          "note": "Find user by claim_keyword",
          "parameters": {
            "spreadsheet_id": "SPREADSHEET_ID",
            "sheet_name": "USERS_SHEET"
          },
          "mapper": {}
        },
        {
          "id": 4,
          "module": "google-sheets:searchRows",
          "version": 1,
          "note": "Find lead by lead_id",
          "parameters": {
            "spreadsheet_id": "SPREADSHEET_ID",
            "sheet_name": "LEADS_SHEET"
          },
          "mapper": {}
        },
        {
          "id": 5,
          "module": "flow:router",
          "version": 1,
          "note": "Route A valid claim / B claimed / C invalid",
          "parameters": {},
          "mapper": {}
        },
        {
          "id": 6,
          "module": "google-sheets:updateRow",
          "version": 1,
          "note": "Route A: set owner + claimed_at + status",
          "parameters": {},
          "mapper": {}
        },
        {
          "id": 7,
          "module": "twilio:sendMessage",
          "version": 1,
          "note": "Route A: send claim success",
          "parameters": {},
          "mapper": {}
        },
        {
          "id": 8,
          "module": "twilio:sendMessage",
          "version": 1,
          "note": "Route B: already claimed message",
          "parameters": {},
          "mapper": {}
        },
        {
          "id": 9,
          "module": "twilio:sendMessage",
          "version": 1,
          "note": "Route C: bad command help text",
          "parameters": {},
          "mapper": {}
        }
      ]
    }
  ],
  "placeholders": {
    "connections": [
      "google_sheets_connection",
      "twilio_connection",
      "make_data_store_connection"
    ],
    "ids_to_replace": [
      "SPREADSHEET_ID",
      "LEADS_SHEET",
      "USERS_SHEET",
      "AUDIT_LOG_SHEET",
      "DATA_STORE_ID"
    ]
  }
}
