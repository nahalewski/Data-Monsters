{
  "metadata": {
    "blueprint_version": 1,
    "name": "06 - Customer Confirmation Handler",
    "description": "Template blueprint generated from shared Lead Management System plan.",
    "scenario": {
      "sequential": true,
      "auto_commit": true,
      "max_errors": 3,
      "schedule": {
        "type": "immediately"
      }
    }
  },
  "subflows": [
    {
      "name": "Main flow",
      "flow": [
        {
          "id": 1,
          "module": "webhooks:customWebhook",
          "version": 1,
          "note": "Trigger: customer_reply webhook",
          "parameters": {
            "webhook_name": "customer_reply"
          },
          "mapper": {}
        },
        {
          "id": 2,
          "module": "data-store:getRecord",
          "version": 1,
          "note": "Find lead session by customer phone",
          "parameters": {
            "data_store_id": "DATA_STORE_ID"
          },
          "mapper": {}
        },
        {
          "id": 3,
          "module": "flow:router",
          "version": 1,
          "note": "Route YES / NO / UNKNOWN",
          "parameters": {},
          "mapper": {}
        },
        {
          "id": 4,
          "module": "google-sheets:updateRow",
          "version": 1,
          "note": "YES: DONE_CONFIRMED + READY_TO_INVOICE",
          "parameters": {},
          "mapper": {}
        },
        {
          "id": 5,
          "module": "data-store:updateRecord",
          "version": 1,
          "note": "YES: awaiting_completion_reply=false",
          "parameters": {},
          "mapper": {}
        },
        {
          "id": 6,
          "module": "twilio:sendMessage",
          "version": 1,
          "note": "YES: thank-you response",
          "parameters": {},
          "mapper": {}
        },
        {
          "id": 7,
          "module": "google-sheets:updateRow",
          "version": 1,
          "note": "NO: FOLLOWUP_REQUIRED",
          "parameters": {},
          "mapper": {}
        },
        {
          "id": 8,
          "module": "twilio:sendMessage",
          "version": 1,
          "note": "NO: alert dispatcher",
          "parameters": {},
          "mapper": {}
        },
        {
          "id": 9,
          "module": "twilio:sendMessage",
          "version": 1,
          "note": "UNKNOWN: prompt YES/NO",
          "parameters": {},
          "mapper": {}
        }
      ]
    }
  ],
  "placeholders": {
    "connections": [
      "google_sheets_connection",
      "twilio_connection",
      "make_data_store_connection"
    ],
    "ids_to_replace": [
      "SPREADSHEET_ID",
      "LEADS_SHEET",
      "USERS_SHEET",
      "AUDIT_LOG_SHEET",
      "DATA_STORE_ID"
    ]
  }
}
